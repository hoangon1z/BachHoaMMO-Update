# Backend URL (server-side only, not exposed to client)
BACKEND_URL=http://localhost:3001

# Socket.IO URL (client-side). If not set, the app will try to auto-detect.
# For local development:
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Encryption key for AES-256 encryption (must be same on client/server)
# Change this in production!
NEXT_PUBLIC_ENCRYPTION_KEY=your-super-secret-encryption-key-change-in-production-2024

# Note: All API calls now go through obfuscated encrypted routes at /api/v1/q/*
