# ============================================
# MMO MARKET - FRONTEND CONFIGURATION
# Domain: ===========

# ============================================
# BACKEND URL (Server-side only)
# Used by Next.js API routes to proxy requests
# On same server: 
# ============================================
BACKEND_URL=

# ============================================
# PUBLIC API URL (Client-side)
# Use /api for proxy through Next.js
# ============================================
NEXT_PUBLIC_API_URL=/api

# ============================================
# SOCKET URL (Client-side)
# For real-time chat connection
# ============================================
NEXT_PUBLIC_SOCKET_URL=

# ============================================
# ENCRYPTION KEY (must match backend)
# ============================================
NEXT_PUBLIC_ENCRYPTION_KEY=
