// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("BUYER") // BUYER, SELLER, ADMIN
  isSeller  Boolean  @default(false)
  isBanned  Boolean  @default(false)    // User is banned from the platform
  banReason String?                      // Reason for the ban
  bannedAt  DateTime?                    // When the user was banned
  avatar    String?
  phone     String?
  address   String?
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 2FA & Password Reset
  twoFactorEnabled  Boolean  @default(false)
  twoFactorCode     String?
  twoFactorExpires  DateTime?
  resetOtp          String?
  resetOtpExpires   DateTime?

  // Telegram Integration - Order Bot (thông báo đơn hàng)
  telegramChatId    String?   // Chat ID for Order Bot notifications
  telegramLinkedAt  DateTime? // When Order Bot was linked
  
  // Telegram Integration - Chat Bot (thông báo tin nhắn)
  telegramChatBotChatId    String?   // Chat ID for Chat Bot notifications
  telegramChatBotLinkedAt  DateTime? // When Chat Bot was linked
  
  // Chat Moderation - Auto detection system
  isChatRestricted    Boolean   @default(false)  // User has restricted chat (stricter moderation)
  chatRestrictedAt    DateTime?                  // When chat was restricted
  isChatLocked        Boolean   @default(false)  // User cannot send chat messages
  chatLockedAt        DateTime?                  // When chat was locked
  chatLockReason      String?                    // Reason for chat lock

  // Relations
  products           Product[]
  orders             Order[]            @relation("BuyerOrders")
  sales              Order[]            @relation("SellerOrders")
  cart               CartItem[]
  sellerProfile      SellerProfile?
  transactions       Transaction[]
  escrowsAsBuyer     Escrow[]           @relation("BuyerEscrow")
  escrowsAsSeller    Escrow[]           @relation("SellerEscrow")
  complaintsAsBuyer  Complaint[]        @relation("BuyerComplaints")
  complaintsAsSeller Complaint[]        @relation("SellerComplaints")
  complaintMessages  ComplaintMessage[]
  sellerWithdrawals  SellerWithdrawal[]
  boughtInventory    ProductInventory[] @relation("BoughtInventory")
  auctionBids        AuctionBid[]
  notifications      Notification[]
  devices            UserDevice[]
  apiKeys            SellerApiKey[]
  serviceOrdersAsBuyer  ServiceOrder[] @relation("BuyerServiceOrders")
  serviceOrdersAsSeller ServiceOrder[] @relation("SellerServiceOrders")
  webhooks           SellerWebhook[]
  discountCodes      DiscountCode[]     @relation("SellerDiscountCodes")
  
  // Blog relations
  blogPosts          BlogPost[]
  blogComments       BlogComment[]
  blogLikes          BlogLike[]
  blogBookmarks      BlogBookmark[]

  // CheckUID relations
  telegramCheckUidId String?   // Telegram ID for CheckUID bot linking
  checkUidItems      CheckUidItem[]
  checkUidSubs       CheckUidSubscription[]

  @@map("users")
}

model SellerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopName        String
  shopSlug        String?  @unique  // SEO-friendly URL slug for shop
  shopDescription String?
  shopLogo        String?
  rating          Float    @default(0)
  totalSales      Int      @default(0)
  commission      Float    @default(10) // Phần trăm hoa hồng
  isVerified      Boolean  @default(false)
  
  // Contact information (for admin to contact seller)
  contactPhone    String?   // Số điện thoại liên lạc
  contactTelegram String?   // Telegram username/link
  
  // Store status
  storeStatus     String    @default("ONLINE") // ONLINE, OFFLINE, AWAY
  statusMessage   String?   // Custom status message (e.g. "Đang bận, trả lời chậm")
  
  // Withdrawal PIN (hashed 6-digit PIN)
  withdrawalPin   String?   // SHA256 hash of 6-digit PIN
  
  // Bank information (can only be added once, cannot be edited)
  bankName        String?
  bankAccount     String?
  bankHolder      String?
  bankBranch      String?
  bankInfoAddedAt DateTime? // When bank info was added (if set, cannot be edited)
  
  // Insurance verification (new system - replaces old isVerified)
  insuranceTier     String?   // BRONZE, SILVER, GOLD, DIAMOND, VIP
  insuranceLevel    Int       @default(0)  // 0=none, 1=bronze, 2=silver, 3=gold, 4=diamond, 5=vip
  
  // Pinned products for homepage display (auction winner feature)
  pinnedProductIds  String?   // JSON array of product IDs (max 4)
  
  // Auto-reply settings (tin nhắn tự động khi offline)
  autoReplyEnabled    Boolean  @default(false)
  autoReplyMessage    String?  // Nội dung tin nhắn tự động
  autoReplyStartHour  Int?     // Giờ bắt đầu (0-23, VD: 22 = 10PM)
  autoReplyEndHour    Int?     // Giờ kết thúc (0-23, VD: 8 = 8AM)
  autoReplyCooldown   Int      @default(30)  // Cooldown phút giữa 2 lần gửi auto-reply cho cùng 1 người
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  insuranceFund   InsuranceFund?

  @@map("seller_profiles")
}

// ============================================
// SELLER INSURANCE FUND SYSTEM
// ============================================

model InsuranceFund {
  id              String    @id @default(uuid())
  sellerId        String    @unique
  sellerProfile   SellerProfile @relation(fields: [sellerId], references: [userId], onDelete: Cascade)
  
  // Tier: BRONZE, SILVER, GOLD, DIAMOND, VIP
  tier            String    @default("BRONZE")
  level           Int       @default(1)  // 1-5
  
  // Financial
  depositAmount   Float     // Tiền cọc ban đầu
  currentBalance  Float     // Số dư hiện tại (có thể bị trừ do tranh chấp)
  maxCoverage     Float     // Hạn mức BH tối đa mỗi đơn
  annualFee       Float     // Phí duy trì hàng năm
  
  // Status
  status          String    @default("ACTIVE")  // ACTIVE, SUSPENDED, WITHDRAWN, REVOKED
  
  // Dates
  activatedAt     DateTime  @default(now())     // Ngày kích hoạt
  nextRenewalAt   DateTime                       // Ngày gia hạn tiếp theo
  withdrawnAt     DateTime?                      // Ngày rút (nếu có)
  revokedAt       DateTime?                      // Ngày bị thu hồi (nếu có)
  
  // Withdraw policy
  canWithdrawFull Boolean   @default(false)      // true sau 6 tháng
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  history         InsuranceFundHistory[]

  @@index([status])
  @@map("insurance_funds")
}

// Lịch sử thay đổi quỹ BH
model InsuranceFundHistory {
  id              String    @id @default(uuid())
  fundId          String
  fund            InsuranceFund @relation(fields: [fundId], references: [id], onDelete: Cascade)
  
  type            String    // DEPOSIT, WITHDRAW, DEDUCTION, UPGRADE, RENEWAL, REVOKE, INFO_CHANGE
  amount          Float     // Số tiền thay đổi (+/-)
  balanceBefore   Float     // Số dư trước
  balanceAfter    Float     // Số dư sau
  description     String    // Mô tả
  metadata        String?   // JSON data bổ sung
  
  createdAt       DateTime  @default(now())

  @@index([fundId])
  @@index([type])
  @@map("insurance_fund_history")
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  icon        String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("categories")
}

model Product {
  id            String   @id @default(uuid())
  title         String
  slug          String?  @unique  // SEO-friendly URL slug (optional during migration, will be required later)
  description   String
  price       Float    // Giá bán (khách trả)
  salePrice   Float?   // Giá gốc (gạch ngang) - API trả về dưới tên originalPrice
  stock       Int      @default(0)
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE, OUT_OF_STOCK
  images      String // JSON array of image URLs
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  commission  Float    @default(5) // Phần trăm hoa hồng sàn (1-100%)
  views       Int      @default(0)
  sales       Int      @default(0)
  rating      Float    @default(0)
  tags        String? // JSON array of tags
  attributes  String? // JSON object for custom attributes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Digital product fields
  isDigital         Boolean          @default(true) // Sản phẩm số
  accountTemplateId String?          // Template định dạng tài khoản
  accountTemplate   AccountTemplate? @relation("ProductTemplate", fields: [accountTemplateId], references: [id])
  autoDelivery      Boolean          @default(true) // Tự động giao hàng khi mua
  
  // Product type: STANDARD (bán tài khoản), UPGRADE (nâng cấp tài khoản của buyer), SERVICE (dịch vụ buff like/sub)
  productType       String           @default("STANDARD") // STANDARD, UPGRADE, SERVICE
  // Các trường buyer cần cung cấp khi mua sản phẩm UPGRADE (JSON array)
  // VD: ["email", "password"] hoặc ["email"]
  requiredBuyerFields String?

  // ====== SERVICE-specific fields (chỉ dùng khi productType = SERVICE) ======
  // Nền tảng: FACEBOOK, INSTAGRAM, TIKTOK, YOUTUBE, TELEGRAM, TWITTER, THREADS, SHOPEE, OTHER
  servicePlatform     String?
  // Loại dịch vụ: LIKE, FOLLOW, SUBSCRIBE, VIEW, COMMENT, SHARE, REACTION, REVIEW, OTHER
  serviceType         String?
  // Giá mỗi đơn vị (VD: 50đ/like) - price trở thành giá hiển thị min
  pricePerUnit        Float?     // Giá mỗi đơn vị
  minQuantity         Int?       @default(100)   // Số lượng tối thiểu
  maxQuantity         Int?       @default(10000) // Số lượng tối đa
  estimatedTime       String?    // Thời gian dự kiến: "1-6 giờ", "12-24 giờ"
  warrantyDays        Int?       @default(0)     // Số ngày bảo hành (0 = không bảo hành)
  serviceSpeed        String?    // SLOW, MEDIUM, FAST
  serviceNote         String?    // Ghi chú thêm cho buyer (VD: "Tài khoản phải để công khai")

  // Product Variants
  hasVariants Boolean          @default(false) // Có phân loại hay không
  variants    ProductVariant[]

  // Relations
  orderItems    OrderItem[]
  cartItems     CartItem[]
  inventory     ProductInventory[]
  serviceOrders ServiceOrder[]

  @@map("products")
}

// Phân loại sản phẩm (VD: 1 tháng, 2 tháng, 1 năm)
model ProductVariant {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String   // "1 tháng", "2 tháng", "1 năm"
  price     Float    // Giá bán
  salePrice Float?   // Giá gốc (gạch ngang) - API trả về dưới tên originalPrice
  stock     Int      @default(0)
  position  Int      @default(0)  // Thứ tự hiển thị
  isActive    Boolean  @default(true)
  // Loại phân loại: STANDARD (bán tài khoản, giao từ kho) hoặc UPGRADE (nâng cấp, buyer nhập email)
  variantType String   @default("STANDARD") // STANDARD, UPGRADE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  inventory   ProductInventory[]
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@map("product_variants")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Thông tin buyer cung cấp cho sản phẩm UPGRADE (JSON object)
  // VD: {"email": "user@example.com", "password": "abc123"}
  buyerProvidedData String?

  @@unique([userId, productId, variantId])
  @@map("cart_items")
}

model Order {
  id              String   @id @default(uuid())
  orderNumber     String   @unique
  buyerId         String
  buyer           User     @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId        String
  seller          User     @relation("SellerOrders", fields: [sellerId], references: [id])
  status          String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, CANCELLED, REFUNDED, DISPUTED
  subtotal        Float
  commission      Float
  total           Float
  shippingAddress String?
  notes           String?
  discountCodeId  String?
  discountCode    DiscountCode? @relation(fields: [discountCodeId], references: [id])
  discountAmount  Float?  @default(0) // Số tiền đã giảm
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Digital delivery tracking
  deliveredAt     DateTime? // Thời điểm giao hàng hoàn tất
  confirmedAt     DateTime? // Thời điểm buyer xác nhận nhận hàng
  disputeDeadline DateTime? // Hạn cuối khiếu nại

  // Relations
  items      OrderItem[]
  escrow     Escrow?
  complaints Complaint[]
  deliveries OrderDelivery[]

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  variantName String?  // Lưu tên variant tại thời điểm mua
  quantity  Int
  price     Float
  total     Float
  createdAt DateTime @default(now())

  // Digital delivery tracking
  deliveredQuantity Int @default(0) // Số lượng đã giao
  
  // Thông tin buyer cung cấp cho sản phẩm UPGRADE (JSON object)
  // VD: {"email": "user@example.com"} - Email cần upgrade
  buyerProvidedData String?
  // Loại sản phẩm tại thời điểm mua (snapshot)
  productType       String?  // STANDARD, UPGRADE, SERVICE

  // SERVICE order fields (link dịch vụ)
  serviceLink       String?  // Link/URL cần buff (VD: link bài viết FB, link profile IG)
  serviceQuantity   Int?     // Số lượng đặt (VD: 1000 like)

  // Relations
  deliveries    OrderDelivery[]
  serviceOrder  ServiceOrder?

  @@map("order_items")
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // DEPOSIT, WITHDRAW, PURCHASE, REFUND, EARNING
  amount      Float
  status      String   @default("PENDING") // PENDING, COMPLETED, REJECTED
  description String
  orderId     String? // Link to order if transaction is for purchase
  metadata    String? // JSON for additional data (bank info, etc)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("transactions")
}

model Escrow {
  id         String    @id @default(uuid())
  orderId    String    @unique
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyerId    String
  buyer      User      @relation("BuyerEscrow", fields: [buyerId], references: [id])
  sellerId   String
  seller     User      @relation("SellerEscrow", fields: [sellerId], references: [id])
  amount     Float
  status     String    @default("HOLDING") // HOLDING, RELEASED, REFUNDED
  holdUntil  DateTime // Release date (3 days from order)
  releasedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("escrows")
}

model Complaint {
  id          String    @id @default(uuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyerId     String
  buyer       User      @relation("BuyerComplaints", fields: [buyerId], references: [id])
  sellerId    String
  seller      User      @relation("SellerComplaints", fields: [sellerId], references: [id])
  type        String    // PRODUCT_ISSUE, NOT_RECEIVED, WRONG_ITEM, REFUND_REQUEST, OTHER
  title       String
  description String
  status      String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  resolution  String?   // Resolution description
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  messages    ComplaintMessage[]

  @@map("complaints")
}

model ComplaintMessage {
  id          String    @id @default(uuid())
  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User      @relation(fields: [senderId], references: [id])
  message     String
  attachments String?   // JSON array of attachment URLs
  createdAt   DateTime  @default(now())

  @@map("complaint_messages")
}

model SellerWithdrawal {
  id            String    @id @default(uuid())
  sellerId      String
  seller        User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  amount        Float
  fee           Float     @default(0)
  netAmount     Float     // amount - fee
  bankName      String
  bankAccount   String
  bankHolder    String
  status        String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, REJECTED
  rejectedReason String?
  adminNote     String?   // Admin note when approving/rejecting
  processedAt   DateTime?
  completedAt   DateTime?
  transactionId String?   // Reference to Transaction record
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("seller_withdrawals")
}

model Banner {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  description String?
  image       String   // Image URL
  link        String   // Navigation link
  gradient    String?  // CSS gradient class
  icon        String?  // Emoji or icon name
  discount    String?  // Discount badge text
  price       String?  // Display price
  originalPrice String? // Original price (strikethrough)
  position    Int      @default(0) // Display order
  isActive    Boolean  @default(true)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("banners")
}

model CategoryShowcase {
  id          String   @id @default(uuid())
  title       String
  image       String   // Image URL (568x296)
  link        String   // Navigation link (e.g. /explore?category=xxx)
  position    Int      @default(0) // Display order
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("category_showcases")
}

// ============================================
// DIGITAL PRODUCT INVENTORY SYSTEM
// ============================================

// Template định dạng cho từng loại tài khoản
model AccountTemplate {
  id          String   @id @default(uuid())
  name        String   @unique // "Facebook", "Netflix", "Gmail", "Steam Key"...
  slug        String   @unique
  format      String   // "username|password|2fa|gmail|cookie"
  fields      String   // JSON array: ["username", "password", "2fa", "gmail", "cookie"]
  fieldLabels String?  // JSON object: {"username": "Tên đăng nhập", "password": "Mật khẩu"...}
  description String?
  icon        String?  // Icon/emoji for display
  disputeWindow Int    @default(24) // Số giờ cho phép khiếu nại
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  products    Product[] @relation("ProductTemplate")

  @@map("account_templates")
}

// Kho tài khoản của sản phẩm (mỗi dòng = 1 tài khoản)
// InventoryStatus: AVAILABLE, RESERVED, SOLD, DISABLED
model ProductInventory {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  accountData String   // Dữ liệu tài khoản (encrypted or plain)
  hash        String   // Hash để chống trùng lặp/gian lận
  status      String   @default("AVAILABLE") // AVAILABLE, RESERVED, SOLD, DISABLED
  
  // Khi bán
  soldAt      DateTime?
  soldToId    String?
  soldTo      User?    @relation("BoughtInventory", fields: [soldToId], references: [id])
  orderId     String?
  orderItemId String?
  
  // Tracking
  reservedAt    DateTime? // Thời điểm reserve (checkout)
  reserveExpiry DateTime? // Hết hạn reserve
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  delivery    OrderDelivery?

  @@unique([productId, hash]) // Không cho phép trùng hash trong cùng product
  @@index([productId, status])
  @@index([variantId, status])
  @@index([hash])
  @@map("product_inventory")
}

// Lưu tài khoản đã giao cho buyer trong order
model OrderDelivery {
  id            String           @id @default(uuid())
  orderId       String
  order         Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId   String
  orderItem     OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  inventoryId   String           @unique
  inventory     ProductInventory @relation(fields: [inventoryId], references: [id])
  
  // Copy dữ liệu tại thời điểm giao (để lưu trữ bằng chứng)
  accountData   String
  
  // Tracking
  deliveredAt   DateTime         @default(now())
  viewedAt      DateTime?        // Lần đầu buyer xem
  viewCount     Int              @default(0) // Số lần xem
  
  createdAt     DateTime         @default(now())

  @@index([orderId])
  @@index([orderItemId])
  @@map("order_deliveries")
}

// Blacklist tài khoản đã bị báo cáo/có vấn đề
model AccountBlacklist {
  id          String   @id @default(uuid())
  hash        String   @unique // Hash của tài khoản
  reason      String   // Lý do blacklist
  reportedBy  String?  // User ID người báo cáo
  productId   String?  // Product ID liên quan
  orderId     String?  // Order ID liên quan
  createdAt   DateTime @default(now())

  @@map("account_blacklist")
}

// ============================================
// SYSTEM SETTINGS & AUCTION SYSTEM
// ============================================

// Cài đặt hệ thống (admin có thể chỉnh)
model SystemSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// Phiên đấu giá hàng tuần
model Auction {
  id          String    @id @default(uuid())
  weekNumber  Int       // Số tuần trong năm
  year        Int
  startTime   DateTime
  endTime     DateTime
  lastBidAt   DateTime? // Thời điểm bid cuối cùng (cho dynamic end)
  status      String    @default("ACTIVE") // ACTIVE, ENDED, CANCELLED
  createdAt   DateTime  @default(now())

  bids        AuctionBid[]

  @@unique([weekNumber, year])
  @@map("auctions")
}

// Lượt đấu giá của seller
model AuctionBid {
  id          String   @id @default(uuid())
  auctionId   String
  auction     Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  position    Int      // 1, 2, hoặc 3
  amount      Float
  status      String   @default("ACTIVE") // ACTIVE, OUTBID, WON, LOST
  heldAmount  Float    @default(0) // Số tiền tạm giữ từ ví seller
  createdAt   DateTime @default(now())

  @@index([auctionId, position])
  @@index([sellerId])
  @@map("auction_bids")
}

// ============================================
// NOTIFICATION SYSTEM
// ============================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // WELCOME, ADMIN, ORDER, COMPLAINT, SYSTEM, PROMOTION
  title     String
  message   String
  link      String?  // Optional link to redirect
  icon      String?  // Optional icon name
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================
// REVIEW SYSTEM
// ============================================

model Review {
  id        String   @id @default(uuid())
  orderId   String   @unique // One review per order
  productId String
  buyerId   String
  sellerId  String
  rating    Int      // 1-5 stars
  comment   String?
  images    String?  // JSON array of image URLs
  isAnonymous Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Seller response
  sellerResponse   String?
  sellerRespondedAt DateTime?

  @@index([productId])
  @@index([sellerId])
  @@index([buyerId])
  @@map("reviews")
}

// ============================================
// SELLER APPLICATION SYSTEM
// ============================================

model SellerApplication {
  id            String   @id @default(uuid())
  userId        String
  fullName      String
  shopName      String
  email         String
  phone         String?
  description   String?  // Why want to become seller
  agreement     Boolean  @default(true) // Agreed to terms
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  adminNote     String?  // Admin rejection/approval note
  reviewedBy    String?  // Admin ID who reviewed
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("seller_applications")
}

// ============================================
// SELLER API KEY SYSTEM
// ============================================

model SellerApiKey {
  id          String    @id @default(uuid())
  sellerId    String
  seller      User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  apiKey      String    @unique  // Prefix: "bhmmo_" + random 32 chars
  secretHash  String              // SHA256 hash of secret (không lưu plaintext)
  name        String    @default("Default API Key")
  
  // Permissions (đơn giản - full access cho phase 1)
  isActive    Boolean   @default(true)
  
  // Rate limiting
  rateLimit   Int       @default(100)  // requests per minute
  
  // Tracking
  lastUsedAt  DateTime?
  lastUsedIp  String?
  totalCalls  Int       @default(0)
  
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?              // null = never expires
  
  @@index([sellerId])
  @@index([apiKey])
  @@map("seller_api_keys")
}

// ============================================
// SELLER WEBHOOK SYSTEM
// ============================================

model SellerWebhook {
  id          String    @id @default(uuid())
  sellerId    String
  seller      User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  url         String              // Webhook endpoint URL
  secret      String              // Secret for signing payloads (HMAC-SHA256)
  name        String    @default("Default Webhook")
  
  // Events to subscribe
  events      String              // JSON array: ["order.created", "order.paid", ...]
  
  // Status
  isActive    Boolean   @default(true)
  
  // Tracking
  lastTriggeredAt DateTime?
  lastStatus      Int?            // Last HTTP status code
  failureCount    Int       @default(0)  // Consecutive failures
  totalCalls      Int       @default(0)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  logs        WebhookLog[]
  
  @@index([sellerId])
  @@index([isActive])
  @@map("seller_webhooks")
}

model WebhookLog {
  id          String    @id @default(uuid())
  webhookId   String
  webhook     SellerWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  
  event       String              // Event type
  payload     String              // JSON payload sent
  
  // Response
  statusCode  Int?                // HTTP response code
  response    String?             // Response body (truncated)
  error       String?             // Error message if failed
  
  // Timing
  duration    Int?                // Request duration in ms
  attempts    Int       @default(1)  // Number of delivery attempts
  
  // Status
  status      String    @default("PENDING")  // PENDING, SUCCESS, FAILED, RETRYING
  
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?
  
  @@index([webhookId])
  @@index([status])
  @@index([createdAt])
  @@map("webhook_logs")
}

// ============================================
// DEVICE MANAGEMENT
// ============================================

model UserDevice {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId     String   // Unique device fingerprint
  deviceName   String?  // Browser/OS name
  deviceType   String?  // desktop, mobile, tablet
  browser      String?
  os           String?
  ipAddress    String?
  location     String?  // City, Country from IP
  lastActive   DateTime @default(now())
  createdAt    DateTime @default(now())
  isActive     Boolean  @default(true)
  isTrusted    Boolean  @default(false) // Trusted device (skip 2FA)
  trustExpires DateTime? // When trust expires

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("user_devices")
}

// ============================================
// BLOG SYSTEM (for verified sellers to share MMO knowledge)
// ============================================

model BlogPost {
  id          String   @id @default(uuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  title       String
  slug        String   @unique
  excerpt     String?  // Short description for preview
  content     String   // Full blog content (markdown/html)
  coverImage  String?  // Cover image URL
  
  // Categorization
  tags        String?  // JSON array of tags
  category    String?  // General category
  
  // Status
  status      String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  publishedAt DateTime?
  
  // Engagement metrics
  views       Int      @default(0)
  likesCount  Int      @default(0)
  commentsCount Int    @default(0)
  bookmarksCount Int   @default(0)
  
  // SEO
  metaTitle       String?
  metaDescription String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  comments    BlogComment[]
  likes       BlogLike[]
  bookmarks   BlogBookmark[]

  @@index([authorId])
  @@index([status, publishedAt])
  @@index([slug])
  @@map("blog_posts")
}

model BlogComment {
  id        String   @id @default(uuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  content   String
  
  // Reply support
  parentId  String?
  parent    BlogComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   BlogComment[] @relation("CommentReplies")
  
  // Status
  isHidden  Boolean  @default(false) // Admin can hide inappropriate comments
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@map("blog_comments")
}

model BlogLike {
  id        String   @id @default(uuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("blog_likes")
}

model BlogBookmark {
  id        String   @id @default(uuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("blog_bookmarks")
}

// ============================================
// TELEGRAM DEPOSIT NOTIFICATION SYSTEM
// ============================================

// Lưu danh sách tài khoản Telegram nhận thông báo nạp tiền (tối đa 5)
model TelegramDepositNotification {
  id          String   @id @default(uuid())
  telegramId  String   @unique  // Telegram User ID hoặc Chat ID
  name        String?           // Tên hiển thị / Ghi chú
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("telegram_deposit_notifications")
}

// ============================================
// CHAT MODERATION SYSTEM
// ============================================

// Lưu lịch sử vi phạm chat của users
model ChatViolation {
  id              String   @id @default(uuid())
  userId          String
  conversationId  String?  // MongoDB conversation ID (string reference)
  messageId       String?  // MongoDB message ID (string reference)
  
  content         String   // Message content that violated (truncated)
  violationType   String   // PHONE_NUMBER, EMAIL, SOCIAL_MEDIA, EXTERNAL_LINK, BANK_INFO, OFF_PLATFORM_TRANSACTION
  severity        String   // LOW, MEDIUM, HIGH, CRITICAL
  score           Int      // Violation score
  matchedPatterns String   // JSON array of matched patterns
  action          String   // WARN, BLOCK, BLOCK_AND_WARN, BLOCK_AND_RESTRICT, BLOCK_AND_LOCK
  
  // Admin review
  isReviewed      Boolean  @default(false)
  reviewedBy      String?  // Admin ID who reviewed
  reviewNote      String?  // Admin note
  reviewedAt      DateTime?
  
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([severity])
  @@map("chat_violations")
}

model Page {
  id          String   @id @default(uuid())
  slug        String   @unique  // e.g. "terms", "privacy", "refund-policy"
  title       String
  content     String   // HTML content
  description String?  // Meta description
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("pages")
}

// ============================================
// CheckUID - Facebook/TikTok Monitoring Tool
// ============================================

model CheckUidPlan {
  id            String   @id @default(uuid())
  name          String   // "1 tháng", "3 tháng", "6 tháng", "12 tháng"
  durationDays  Int      // 30, 90, 180, 365
  price         Float    // Giá VNĐ
  originalPrice Float?   // Giá gốc (nếu có giảm giá)
  description   String?
  features      String?  // JSON string of features
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions CheckUidSubscription[]

  @@map("checkuid_plans")
}

model CheckUidSubscription {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId      String
  plan        CheckUidPlan @relation(fields: [planId], references: [id])
  startDate   DateTime @default(now())
  endDate     DateTime
  amount      Float    // Số tiền đã trả
  status      String   @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("checkuid_subscriptions")
}

model CheckUidItem {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform      String   // "facebook" or "tiktok"
  type          String   @default("profile") // profile, group, post (for facebook)
  uid           String   // Facebook UID or TikTok username
  link          String?  // Original URL
  note          String?
  price         Float    @default(0) // Giá trị tài khoản
  status        String   @default("unknown") // live, die, unknown
  previousStatus String? 
  avatarUrl     String?
  lastCheckedAt DateTime?
  expiresAt     DateTime? // Tracking expiry
  telegramBotId String?  // Link to bot DB record if synced from Telegram
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  history       CheckUidHistory[]

  @@unique([userId, platform, uid])
  @@map("checkuid_items")
}

model CheckUidHistory {
  id          String   @id @default(uuid())
  itemId      String
  item        CheckUidItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  oldStatus   String
  newStatus   String
  checkedAt   DateTime @default(now())

  @@map("checkuid_history")
}

// ============================================
// DISCOUNT CODE SYSTEM
// ============================================

model DiscountCode {
  id            String   @id @default(uuid())
  code          String   @unique  // Mã giảm giá (VD: SALE10, BHOA2024)
  sellerId      String            // Seller tạo mã (chỉ dùng cho sản phẩm của seller đó)
  seller        User     @relation("SellerDiscountCodes", fields: [sellerId], references: [id], onDelete: Cascade)

  // Loại giảm giá
  type          String   @default("PERCENT") // PERCENT (%) hoặc FIXED (VNĐ cố định)
  value         Float    // Giá trị giảm (10 = 10% hoặc 10000 = 10.000đ)
  maxDiscount   Float?   // Số tiền giảm tối đa (chỉ áp dụng khi type=PERCENT)

  // Điều kiện sử dụng
  minOrderValue Float    @default(0)  // Đơn hàng tối thiểu
  usageLimit    Int?     // Số lần sử dụng tối đa (null = không giới hạn)
  usageCount    Int      @default(0)  // Số lần đã dùng

  // Giới hạn per user
  usageLimitPerUser Int? @default(1) // Mỗi user dùng tối đa bao nhiêu lần (null = không giới hạn)

  // Giới hạn sản phẩm cụ thể (JSON array of productId strings, null = áp dụng tất cả)
  productIds    String?  // JSON: ["id1","id2"] hoặc null = toàn gian hàng

  // Mô tả (để seller ghi chú mục đích: bồi thường / khuyến mãi)
  description   String?

  // Thời hạn
  startsAt      DateTime?  // Ngày bắt đầu (null = ngay lập tức)
  expiresAt     DateTime?  // Ngày hết hạn (null = không hết hạn)

  // Trạng thái
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  usages        DiscountCodeUsage[]
  orders        Order[]

  @@index([sellerId])
  @@index([code])
  @@index([isActive])
  @@map("discount_codes")
}

// Lịch sử sử dụng mã giảm giá (để kiểm tra per-user limit)
model DiscountCodeUsage {
  id              String       @id @default(uuid())
  discountCodeId  String
  discountCode    DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)
  userId          String
  orderId         String       @unique
  discountAmount  Float        // Số tiền thực tế được giảm
  createdAt       DateTime     @default(now())

  @@unique([discountCodeId, userId, orderId])
  @@index([discountCodeId])
  @@index([userId])
  @@map("discount_code_usages")
}

// ============================================
// SERVICE ORDER SYSTEM (Buff Like/Sub MXH)
// ============================================

// Đơn dịch vụ - Theo dõi tiến độ buff like/sub
model ServiceOrder {
  id              String   @id @default(uuid())
  
  // Liên kết đơn hàng
  orderItemId     String   @unique
  orderItem       OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  buyerId         String
  buyer           User     @relation("BuyerServiceOrders", fields: [buyerId], references: [id])
  sellerId        String
  seller          User     @relation("SellerServiceOrders", fields: [sellerId], references: [id])
  
  // Thông tin dịch vụ
  serviceLink     String   // Link/URL cần buff
  platform        String   // FACEBOOK, INSTAGRAM, TIKTOK, YOUTUBE...
  serviceType     String   // LIKE, FOLLOW, VIEW, COMMENT...
  
  // Số lượng & tiến độ
  quantity        Int      // Số lượng đã đặt (VD: 1000 like)
  delivered       Int      @default(0)  // Số lượng đã giao (VD: 750/1000)
  progress        Float    @default(0)  // Phần trăm tiến độ (0-100)
  
  // Trạng thái 
  // PENDING: Mới tạo, chờ seller xử lý
  // PROCESSING: Seller đang chạy dịch vụ
  // COMPLETED: Hoàn thành đủ số lượng
  // PARTIAL: Hoàn thành 1 phần (hoàn tiền phần còn lại)
  // CANCELLED: Hủy đơn (hoàn tiền toàn bộ)
  status          String   @default("PENDING")
  
  // Thời gian
  startedAt       DateTime?   // Seller bắt đầu xử lý
  completedAt     DateTime?   // Hoàn thành
  
  // Hoàn tiền partial
  refundedAmount  Float?      // Số tiền hoàn trả (nếu partial)
  
  // Bảo hành
  warrantyDays    Int      @default(0)    // Số ngày bảo hành
  warrantyExpiry  DateTime?              // Hạn bảo hành
  
  // Ghi chú
  sellerNote      String?  // Ghi chú của seller
  cancelReason    String?  // Lý do hủy
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  warrantyRequests ServiceWarrantyRequest[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([productId])
  @@map("service_orders")
}

// Yêu cầu bảo hành dịch vụ (khi like/sub bị tụt)
model ServiceWarrantyRequest {
  id              String   @id @default(uuid())
  serviceOrderId  String
  serviceOrder    ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  
  // Thông tin yêu cầu
  currentCount    Int      // Số lượng hiện tại (VD: đặt 1000 nhưng còn 800)
  requestedCount  Int      // Số lượng cần bù (VD: 200)
  evidence        String?  // Screenshot URL chứng minh bị tụt
  buyerNote       String?  // Ghi chú của buyer
  
  // Trạng thái: PENDING, APPROVED, REJECTED, COMPLETED
  status          String   @default("PENDING")
  sellerNote      String?  // Ghi chú khi seller xử lý
  
  // Bù bảo hành
  deliveredCount  Int      @default(0)  // Số lượng seller đã bù
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([serviceOrderId])
  @@index([status])
  @@map("service_warranty_requests")
}
