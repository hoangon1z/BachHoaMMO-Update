# ============================================
# DATABASE
# ============================================
DATABASE_URL="file:./dev.db"

# ============================================
# JWT CONFIGURATION (OAuth 2.1 compliant)
# ============================================
JWT_SECRET="your-super-secure-jwt-secret-key-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================
# SECURITY CONFIGURATION
# ============================================
# Encryption key for sensitive data (32 bytes hex)
ENCRYPTION_KEY="your-32-byte-encryption-key-in-hex-format"

# Strict mode - reject requests on device mismatch
SECURITY_STRICT_MODE=false

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development

# CORS origins (comma-separated)
CORS_ORIGIN="http://localhost:3000"

# ============================================
# RATE LIMITING (optional overrides)
# ============================================
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_AUTH=5
RATE_LIMIT_API=60

# ============================================
# REDIS (optional - for production)
# ============================================
# REDIS_URL="redis://localhost:6379"

# ============================================
# EXTERNAL SERVICES (optional)
# ============================================
# SENTRY_DSN=""
# SLACK_WEBHOOK_URL=""

# ============================================
# PAYOS PAYMENT GATEWAY
# Get credentials from: https://my.payos.vn
# ============================================
PAYOS_CLIENT_ID="your-client-id"
PAYOS_API_KEY="your-api-key"
PAYOS_CHECKSUM_KEY="your-checksum-key"
PAYOS_BASE_URL="https://api-merchant.payos.vn"

# Frontend URL for payment callbacks
FRONTEND_URL="http://localhost:3000"

# ============================================
# EMAIL SERVICE (chọn 1 - đều dùng HTTP API, không bị DigitalOcean chặn)
# ============================================

# --- Option A: SendGrid (100 email/ngày free)
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY="SG.xxx..."
# SENDGRID_FROM_EMAIL="noreply@yourdomain.com"
# SENDGRID_FROM_NAME="BachHoaMMO"

# --- Option B: Resend (100 email/ngày free) - https://resend.com
# EMAIL_PROVIDER=resend
# RESEND_API_KEY="re_xxx..."
# RESEND_FROM_EMAIL="onboarding@resend.dev"   # hoặc domain đã verify
# RESEND_FROM_NAME="BachHoaMMO"

# --- Option C: Brevo / Sendinblue (300 email/ngày free) - https://brevo.com
# EMAIL_PROVIDER=brevo
# BREVO_API_KEY="xkeysib-xxx..."
# BREVO_FROM_EMAIL="noreply@yourdomain.com"
# BREVO_FROM_NAME="BachHoaMMO"

# --- Option D: Gmail SMTP (cần mở port 465/587 - DigitalOcean thường chặn)
# GMAIL_USER="your-email@gmail.com"
# GMAIL_APP_PASSWORD="your-16-char-app-password"
