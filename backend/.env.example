# ============================================
# MMO MARKET - BACKEND CONFIGURATION
# Domain: 
# ============================================

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV="production"
PORT=3001

# ============================================
# DATABASE
# ============================================
# SQLite (for development)
DATABASE_URL=""

# MongoDB (for chat)
MONGODB_URL=""

# Redis (for caching/sessions)
REDIS_URL=""

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=""

# ============================================
# FRONTEND URL (for redirects & callbacks)
# ============================================
FRONTEND_URL=""

# ============================================
# PAYOS PAYMENT GATEWAY - BIDV (Primary)
# Get credentials from: https://my.payos.vn
# ============================================
PAYOS_CLIENT_ID=""
PAYOS_API_KEY=""
PAYOS_CHECKSUM_KEY="1"
PAYOS_BASE_URL=""

# ============================================
# PAYOS PAYMENT GATEWAY - MBBANK (Secondary)
# ============================================
PAYOS_MB_CLIENT_ID=""
PAYOS_MB_API_KEY=""
PAYOS_MB_CHECKSUM_KEY=""

# ============================================
# EMAIL SERVICE (Gmail SMTP)
# ============================================
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# ============================================
# ENCRYPTION KEY (must match frontend)
# ============================================
ENCRYPTION_KEY=""
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=BachHoaMMOTELEGRAM_BOT_TOKEN=
